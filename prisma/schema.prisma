generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  password     String
  phone        String?    
  role         String     @default("CUSTOMER") // "ADMIN" or "CUSTOMER"
  referralCode String?    @unique
  rewardClaimed Boolean   @default(false)
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  referrals    Referral[] @relation("ReferrerToReferral")
}

model Referral {
  id                 String   @id @default(cuid())
  referredEmail      String   @unique
  referredName       String
  hasConsumedService Boolean  @default(false)
  isRewardClaimed    Boolean  @default(false) // Whether this referral was already part of a claimed reward
  
  referrerId         String
  referrer           User     @relation("ReferrerToReferral", fields: [referrerId], references: [id])
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Settings {
  id          String   @id @default("global")
  rewardText  String   @default("Corte de cabello gratis")
  updatedAt   DateTime @updatedAt
}
